<!DOCTYPE html>
<html>
    <head>
        <title>Document</title>
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="stylesheet" href="/stylesheets/style.css">
        <!--Tail wind script -->
        <script src="https://cdn.tailwindcss.com"></script>
    </head>
    <body>
        <script src="/javascripts/script.js"></script>
        <!-- Upper Notes Typing List -->
        <div class="main w-full min-h-screen">
            <div class="form px-10 py-10">
                <form action="/create" method="post">
                    <input class="block w-full rounded-md px-5 py-2" placeholder="Title Goes Here" name="title"></input>
                    <textarea class="mt-3 block w-full rounded-md px-5 py-2" resize-none placeholder="Write Your Task Details Here..." name="details"></textarea>
                    <input class="mt-3 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="Create Task"></input>
                </form>
            </div>
            <!-- Tasks List -->
            <div class="tasks flex gap-3 p-10 flex-wrap">
                <% if (files.length>0){ %>
                    <% files.forEach(function(val){ %>
                        <div class="task min-w-72 px-2 py-4 rounded-md bg-blue-800">
                            <h1 class="text-white text-2xl tracking-tighter"><%= val %></h1>
                            <a class="text-white-800 initial-block mt-3" href="">Read More</a>
                        </div>
                    <%}) %>
                <%} else { %>
                    <h3 class="text-white-600">No Task Yet.</h3>
                <%} %>
            </div>

            <!-- Sample notes card pop-up appearin code 

            <div class="task w-72 px-2 py-4 rounded-md bg-blue-800">
                <h1 class="text-white text-2xl tracking-tighter">Some Tasks Goes Here</h1>
                <a class="text-white-600 initial-block mt-3" href="">Read More</a>
            </div>
            -->
        </div>
    </body>
</html> 